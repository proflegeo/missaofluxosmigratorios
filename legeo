<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Desafio Geopolítico: Map Skill</title>
    <style>
        :root {
            --primary: #0f172a;
            --accent: #e67e22;
            --success: #10b981;
            --bg: #f1f5f9;
            --text: #1e293b;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            text-align: center;
            padding: 20px;
        }

        .game-container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        #quiz-zone {
            background-color: var(--primary);
            color: white;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 1.2rem;
            font-weight: bold;
        }

        #score-counter {
            color: var(--accent);
            margin-left: 15px;
        }

        .map-wrapper {
            position: relative;
            display: inline-block;
            cursor: crosshair;
        }

        .map-wrapper img {
            max-width: 100%;
            height: auto;
            border-radius: 8px;
        }

        #info-dossier {
            display: none;
            margin-top: 20px;
            padding: 20px;
            background-color: #e6f0fa;
            border-left: 5px solid var(--accent);
            border-radius: 4px 8px 8px 4px;
            text-align: left;
            animation: fadeIn 0.5s;
        }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        #btn-next {
            display: none;
            margin-top: 15px;
            background-color: var(--success);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 1rem;
        }
    </style>
</head>
<body>

    <div class="game-container">
        <div id="quiz-zone">
            Fase 1: <span id="question">Onde fica a Catalunha?</span>
            <span id="score-counter">Acertos: <span id="score">0</span></span>
        </div>

        <div class="map-wrapper" onclick="handleMapClick(event)">
            <img src="image_1.png" alt="Mapa Interativo de Separatismo na Europa">
        </div>

        <div id="info-dossier">
            <h3>Dossiê Desbloqueado: Catalunha (Espanha)</h3>
            <p><strong>Motivação:</strong> Econômica/Cultural. Região rica com idioma próprio.</p>
            <p><strong>Tentativas:</strong> Referendo de 2017 e declaração simbólica de independência.</p>
            <p><strong>Anotação no Caderno:</strong> Resuma as consequências políticas do referendo de 2017 para os líderes separatistas.</p>
        </div>
    </div>

    <script>
        let score = 0;

        function handleMapClick(event) {
            const quizZone = document.getElementById('quiz-zone');
            
            // Verificação simplificada: Na imagem_1.png, o aluno deve clicar na região laranja da Espanha.
            // Para este exemplo, qualquer clique no mapa desbloqueia o primeiro dossiê.
            
            // Animação de sucesso rápida
            quizZone.style.backgroundColor = 'var(--success)';
            quizZone.innerText = "Correto! Dossiê Desbloqueado.";

            // Incrementa Score
            score = 1;
            document.getElementById('score').innerText = score;

            // Exibe Dossiê
            document.getElementById('info-dossier').style.display = 'block';

            // O aluno deve agora fazer a anotação no caderno.
        }
    </script>
</body>
</html>
