<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Simulador Geopolítico: Separatismos Europeus</title>
    <style>
        /* ==========================================================================
           VARIÁVEIS E RESET
           ========================================================================== */
        :root {
            --bg-dark: #0f172a;
            --bg-panel: #1e293b;
            --primary: #3b82f6;
            --primary-hover: #2563eb;
            --accent: #f59e0b;
            --success: #10b981;
            --danger: #ef4444;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --border: #334155;
            --font-main: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; user-select: none; }
        
        body {
            font-family: var(--font-main);
            background-color: var(--bg-dark);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        /* ==========================================================================
           UI GLOBAL & CABEÇALHO
           ========================================================================== */
        header {
            background: var(--bg-panel);
            padding: 15px 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.5);
            z-index: 10;
        }

        .brand h1 { font-size: 1.2rem; color: var(--primary); text-transform: uppercase; letter-spacing: 1px; }
        .brand span { color: var(--text-muted); font-size: 0.8rem; }
        
        .hud { display: flex; gap: 15px; font-size: 0.9rem; font-weight: bold; }
        .hud-item { background: var(--bg-dark); padding: 5px 12px; border-radius: 6px; border: 1px solid var(--border); }
        .hud-accent { color: var(--accent); }

        main { flex: 1; position: relative; display: flex; flex-direction: column; }
        
        .screen {
            display: none;
            flex: 1;
            padding: 20px;
            max-width: 1000px;
            margin: 0 auto;
            width: 100%;
            animation: fadeIn 0.4s ease-out;
        }
        .screen.active { display: flex; flex-direction: column; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        .btn {
            background: var(--primary); color: white; border: none; padding: 12px 24px;
            border-radius: 8px; font-size: 1rem; font-weight: bold; cursor: pointer;
            transition: all 0.2s; text-transform: uppercase; letter-spacing: 0.5px;
        }
        .btn:hover { background: var(--primary-hover); transform: translateY(-2px); }
        .btn:disabled { background: var(--border); color: var(--text-muted); cursor: not-allowed; transform: none; }

        /* ==========================================================================
           TELA 1: MAPA DE RECONHECIMENTO (ESTILO GEOGUESSR)
           ========================================================================== */
        .mission-briefing {
            background: rgba(59, 130, 246, 0.1); border-left: 4px solid var(--primary);
            padding: 15px; margin-bottom: 20px; border-radius: 0 8px 8px 0;
        }
        .mission-briefing h2 { color: var(--primary); font-size: 1.2rem; margin-bottom: 5px; }
        .mission-briefing p { color: var(--text-main); font-size: 1.1rem; }

        .map-container {
            position: relative; width: 100%; aspect-ratio: 4/3; max-height: 60vh;
            background-color: #1e293b; border-radius: 12px; border: 2px solid var(--border);
            overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
            /* Imagem baseada no mapa da Europa - fallback seguro */
            background-image: url('https://upload.wikimedia.org/wikipedia/commons/e/e6/Blank_map_of_Europe.svg');
            background-size: cover; background-position: center; filter: invert(0.8) hue-rotate(180deg) opacity(0.7);
        }

        .radar-pin {
            position: absolute; width: 24px; height: 24px;
            background: var(--accent); border-radius: 50%;
            transform: translate(-50%, -50%); cursor: pointer;
            border: 3px solid white; box-shadow: 0 0 15px var(--accent);
            transition: all 0.2s; z-index: 5;
        }
        .radar-pin::after {
            content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            border-radius: 50%; border: 2px solid var(--accent);
            animation: pulse 1.5s infinite; pointer-events: none;
        }
        @keyframes pulse { 0% { transform: scale(0.5); opacity: 1; } 100% { transform: scale(1.5); opacity: 0; } }
        
        .radar-pin:hover { transform: translate(-50%, -50%) scale(1.2); background: var(--success); }

        /* ==========================================================================
           TELA 2: DOSSIÊ & QUIZ
           ========================================================================== */
        .dossier-layout { display: grid; grid-template-columns: 1fr; gap: 20px; }
        @media (min-width: 768px) { .dossier-layout { grid-template-columns: 3fr 2fr; } }

        .panel { background: var(--bg-panel); padding: 25px; border-radius: 12px; border: 1px solid var(--border); }
        .panel h3 { color: var(--accent); border-bottom: 1px solid var(--border); padding-bottom: 10px; margin-bottom: 15px; }
        
        .info-group { margin-bottom: 15px; }
        .info-group label { display: block; color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 4px; }
        .info-group p { color: var(--text-main); font-size: 1.05rem; line-height: 1.5; }

        .notebook-task {
            background: #fefce8; color: #854d0e; padding: 15px; border-radius: 8px;
            border-left: 4px solid #facc15; margin-top: 20px; font-family: monospace; font-size: 1rem;
        }

        .quiz-container { margin-top: 20px; }
        .quiz-question { font-size: 1.1rem; font-weight: bold; margin-bottom: 15px; }
        .quiz-options { display: flex; flex-direction: column; gap: 10px; }
        .quiz-option {
            background: var(--bg-dark); border: 1px solid var(--border); padding: 12px 15px;
            border-radius: 8px; cursor: pointer; transition: background 0.2s; color: var(--text-main);
        }
        .quiz-option:hover { background: #334155; }
        .quiz-option.correct { background: rgba(16, 185, 129, 0.2); border-color: var(--success); color: var(--success); }
        .quiz-option.wrong { background: rgba(239, 68, 68, 0.2); border-color: var(--danger); color: var(--danger); }

        /* ==========================================================================
           TELA 3: BOSS FINAL (RELACIONAR COLUNAS)
           ========================================================================== */
        .matching-grid { display: flex; justify-content: space-between; gap: 20px; margin-top: 20px; }
        .match-col { flex: 1; display: flex; flex-direction: column; gap: 10px; }
        .match-col h4 { text-align: center; color: var(--text-muted); margin-bottom: 10px; }
        
        .match-item {
            background: var(--bg-panel); border: 2px solid var(--border); padding: 15px;
            border-radius: 8px; cursor: pointer; text-align: center; font-weight: bold; transition: all 0.2s;
        }
        .match-item.selected { border-color: var(--primary); background: rgba(59, 130, 246, 0.2); }
        .match-item.matched { border-color: var(--success); background: rgba(16, 185, 129, 0.1); cursor: default; opacity: 0.7; }
        .match-item.error { border-color: var(--danger); animation: shake 0.4s; }

        @keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }

    </style>
</head>
<body>

    <header>
        <div class="brand">
            <h1>Geopolítica 360</h1>
            <span>Aula Interativa</span>
        </div>
        <div class="hud">
            <div class="hud-item">Nível: <span id="hud-level" class="hud-accent">1/5</span></div>
            <div class="hud-item">Precisão: <span id="hud-score" class="hud-accent">100%</span></div>
        </div>
    </header>

    <main>
        <div id="screen-intro" class="screen active" style="align-items: center; justify-content: center; text-align: center;">
            <h1 style="font-size: 2.5rem; color: var(--primary); margin-bottom: 15px;">Missão: Europa Fragmentada</h1>
            <p style="font-size: 1.2rem; max-width: 600px; color: var(--text-muted); margin-bottom: 30px; line-height: 1.6;">
                Você foi designado para mapear os principais focos de tensão separatista no continente europeu. 
                Sua missão envolve localizar os movimentos, analisar os dossiês de inteligência e registrar os dados críticos no seu caderno.
            </p>
            <button class="btn" onclick="startGame()">Iniciar Simulação</button>
        </div>

        <div id="screen-map" class="screen">
            <div class="mission-briefing">
                <h2>Alvo de Reconhecimento:</h2>
                <p id="map-prompt">Localize a Catalunha no mapa.</p>
            </div>
            <div class="map-container" id="map-container">
                </div>
            <p id="map-feedback" style="margin-top: 15px; text-align: center; font-weight: bold; height: 24px;"></p>
        </div>

        <div id="screen-dossier" class="screen">
            <div class="dossier-layout">
                <div class="panel">
                    <h3 id="dossier-title">Dossiê: Catalunha</h3>
                    <div class="info-group">
                        <label>País Soberano Atual</label>
                        <p id="dossier-country">Espanha</p>
                    </div>
                    <div class="info-group">
                        <label>Idioma / Identidade</label>
                        <p id="dossier-culture">Catalão.</p>
                    </div>
                    <div class="info-group">
                        <label>Histórico e Motivação</label>
                        <p id="dossier-history">Texto rico explicativo.</p>
                    </div>
                    <div class="notebook-task">
                        <strong>✍️ Missão no Caderno:</strong><br>
                        <span id="dossier-task">Anote o ano do referendo e a principal motivação.</span>
                    </div>
                </div>

                <div class="panel">
                    <h3>Validação de Inteligência</h3>
                    <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 15px;">Responda corretamente para provar que processou as informações e liberar a próxima fase.</p>
                    
                    <div class="quiz-container">
                        <div class="quiz-question" id="quiz-question">Pergunta aqui?</div>
                        <div class="quiz-options" id="quiz-options">
                            </div>
                    </div>

                    <div style="margin-top: 30px; text-align: right;">
                        <button class="btn" id="btn-next-mission" disabled onclick="nextPhase()">Próxima Missão</button>
                    </div>
                </div>
            </div>
        </div>

        <div id="screen-boss" class="screen">
            <div style="text-align: center; margin-bottom: 20px;">
                <h2 style="color: var(--primary);">Desafio Final: Síntese Geopolítica</h2>
                <p style="color: var(--text-muted);">Relacione o Movimento Separatista ao seu País correspondente para finalizar a aula.</p>
            </div>
            
            <div class="matching-grid" id="matching-grid">
                </div>
        </div>

        <div id="screen-victory" class="screen" style="align-items: center; justify-content: center; text-align: center;">
            <h1 style="font-size: 3rem; color: var(--success); margin-bottom: 15px;">Missão Cumprida!</h1>
            <p style="font-size: 1.2rem; color: var(--text-muted); max-width: 600px; margin-bottom: 30px;">
                Você mapeou as tensões da Europa com uma precisão de <span id="final-score" class="hud-accent">100%</span>. 
                Seu caderno agora é um portfólio completo sobre o separatismo no Velho Continente.
            </p>
            <button class="btn" onclick="location.reload()">Reiniciar Aula</button>
        </div>

    </main>

    <script>
        /* ==========================================================================
           BANCO DE DADOS DA AULA (CONTEÚDO GEOPOLÍTICO)
           ========================================================================== */
        const gameData = [
            {
                id: 'catalunha',
                region: 'Catalunha',
                country: 'Espanha',
                mapX: 20, mapY: 75, // Coordenadas em % baseadas no mapa europeu (aproximadas para o layout)
                culture: 'Língua e cultura catalãs. Possuem instituições próprias históricas.',
                history: 'Uma das regiões mais ricas e industrializadas da Espanha. A principal motivação atual é econômica e fiscal (sentem que pagam impostos desproporcionais para sustentar o resto do país) e identitária. Em 2017, realizaram um Referendo de Independência considerado ilegal por Madri, resultando na prisão ou fuga de seus líderes e forte tensão política.',
                task: 'Resuma no caderno: Qual foi a motivação principal da Catalunha para o referendo de 2017 e qual foi a reação do governo espanhol?',
                quiz: {
                    q: 'O que culminou na grande crise política da Catalunha em 2017?',
                    options: [
                        { text: 'Um conflito armado iniciado por um grupo terrorista.', isCorrect: false },
                        { text: 'A realização de um referendo unilateral de independência.', isCorrect: true },
                        { text: 'A invasão do território por forças francesas.', isCorrect: false }
                    ]
                }
            },
            {
                id: 'escocia',
                region: 'Escócia',
                country: 'Reino Unido',
                mapX: 28, mapY: 35,
                culture: 'Identidade Celta; Língua inglesa e gaélico escocês.',
                history: 'Faz parte do Reino Unido, mas mantém forte autonomia. Em 2014, realizaram um referendo oficial e a maioria votou por permanecer no Reino Unido. No entanto, a saída do Reino Unido da União Europeia (Brexit) reacendeu o desejo separatista, pois a maioria dos escoceses desejava continuar no bloco europeu.',
                task: 'Anote no caderno: Qual evento político recente (envolvendo a Europa) reacendeu o desejo de independência da Escócia?',
                quiz: {
                    q: 'Por que o nacionalismo escocês ganhou força novamente após 2016?',
                    options: [
                        { text: 'Devido à insatisfação com a saída do Reino Unido da União Europeia (Brexit).', isCorrect: true },
                        { text: 'Porque a Inglaterra tentou proibir o idioma escocês.', isCorrect: false },
                        { text: 'Pela descoberta de novas minas de ouro na região das Highlands.', isCorrect: false }
                    ]
                }
            },
            {
                id: 'paisbasco',
                region: 'País Basco',
                country: 'Espanha',
                mapX: 18, mapY: 70,
                culture: 'Língua Euskara (idioma isolado, sem parentesco na Europa).',
                history: 'Uma região com forte identidade que sofreu severa repressão cultural durante a ditadura de Francisco Franco. Isso gerou o surgimento do ETA, um grupo terrorista que lutou pela independência através de atentados por décadas. Hoje, o ETA foi dissolvido e o movimento separatista atua pacificamente através de partidos políticos.',
                task: 'Pesquise e anote: O que foi o ETA e como o separatismo basco atua nos dias de hoje?',
                quiz: {
                    q: 'Qual é a situação atual do movimento separatista no País Basco?',
                    options: [
                        { text: 'O conflito armado continua sendo a principal forma de atuação.', isCorrect: false },
                        { text: 'A região conquistou independência total da Espanha em 2011.', isCorrect: false },
                        { text: 'O grupo armado ETA foi dissolvido e a busca por autonomia ocorre pela via política.', isCorrect: true }
                    ]
                }
            },
            {
                id: 'irlandanorte',
                region: 'Irlanda do Norte',
                country: 'Reino Unido',
                mapX: 25, mapY: 42,
                culture: 'Divisão profunda: Protestantes (leais ao Reino Unido) vs Católicos (Nacionalistas irlandeses).',
                history: 'Palco de um conflito violento conhecido como "The Troubles" durante décadas. Os nacionalistas (católicos) queriam se separar do Reino Unido e se unir à República da Irlanda, usando o grupo armado IRA. O Acordo de Sexta-Feira Santa (1998) trouxe paz à região, estabelecendo um governo compartilhado.',
                task: 'Anote no caderno: Qual era o principal objetivo dos nacionalistas católicos na Irlanda do Norte?',
                quiz: {
                    q: 'Diferente de outros movimentos, o que os nacionalistas da Irlanda do Norte buscavam?',
                    options: [
                        { text: 'Criar um país totalmente novo e isolado.', isCorrect: false },
                        { text: 'Separar-se do Reino Unido para se reunificar com a República da Irlanda.', isCorrect: true },
                        { text: 'Criar um estado governado inteiramente por líderes católicos.', isCorrect: false }
                    ]
                }
            },
            {
                id: 'kosovo',
                region: 'Kosovo',
                country: 'Sérvia',
                mapX: 58, mapY: 72,
                culture: 'Maioria de etnia Albanesa (muçulmanos), dentro de território histórico Sérvio (cristãos ortodoxos).',
                history: 'Após a desintegração da Iugoslávia nos anos 90, o Kosovo sofreu brutal repressão da Sérvia, gerando uma guerra e intervenção da OTAN. Em 2008, Kosovo declarou independência de forma unilateral. Hoje, é reconhecido por cerca de 100 países, mas a Sérvia, Rússia e outros (inclusive o Brasil) ainda o consideram uma província rebelde.',
                task: 'Anote no caderno: Qual é o status diplomático do Kosovo hoje? Todos os países o consideram um país?',
                quiz: {
                    q: 'Qual é o principal obstáculo geopolítico do Kosovo hoje?',
                    options: [
                        { text: 'Não possui governo próprio constituído.', isCorrect: false },
                        { text: 'Declarou independência, mas não possui reconhecimento internacional unânime (a Sérvia o reivindica).', isCorrect: true },
                        { text: 'A população votou para retornar voluntariamente ao domínio da Iugoslávia.', isCorrect: false }
                    ]
                }
            }
        ];

        /* ==========================================================================
           LÓGICA DO MOTOR DO JOGO
           ========================================================================== */
        let currentPhase = 0;
        let attempts = 0;
        let hits = 0;
        let activeRegion = null;

        const screens = {
            intro: document.getElementById('screen-intro'),
            map: document.getElementById('screen-map'),
            dossier: document.getElementById('screen-dossier'),
            boss: document.getElementById('screen-boss'),
            victory: document.getElementById('screen-victory')
        };

        function switchScreen(screenName) {
            Object.values(screens).forEach(s => s.classList.remove('active'));
            screens[screenName].classList.add('active');
        }

        function updateHUD() {
            document.getElementById('hud-level').innerText = `${Math.min(currentPhase + 1, gameData.length)}/${gameData.length}`;
            let accuracy = attempts === 0 ? 100 : Math.round((hits / attempts) * 100);
            document.getElementById('hud-score').innerText = `${accuracy}%`;
            document.getElementById('final-score').innerText = `${accuracy}%`;
        }

        function startGame() {
            currentPhase = 0;
            attempts = 0;
            hits = 0;
            updateHUD();
            loadMapPhase();
        }

        // --- FASE 1: MAPA ---
        function loadMapPhase() {
            activeRegion = gameData[currentPhase];
            document.getElementById('map-prompt').innerHTML = `Missão: Encontre a base do movimento na <strong>${activeRegion.region}</strong>.`;
            document.getElementById('map-feedback').innerText = "";
            document.getElementById('map-feedback').style.color = "inherit";
            
            const mapContainer = document.getElementById('map-container');
            mapContainer.innerHTML = ''; // Limpa pinos anteriores

            // Cria pinos falsos (distratores)
            for(let i=0; i<4; i++) {
                createPin(
                    Math.random() * 80 + 10, // X aleatório entre 10% e 90%
                    Math.random() * 80 + 10, // Y aleatório
                    false
                );
            }
            
            // Cria o pino verdadeiro
            createPin(activeRegion.mapX, activeRegion.mapY, true);
            
            switchScreen('map');
        }

        function createPin(x, y, isTarget) {
            const pin = document.createElement('div');
            pin.className = 'radar-pin';
            pin.style.left = `${x}%`;
            pin.style.top = `${y}%`;
            
            pin.onclick = () => handlePinClick(isTarget, pin);
            document.getElementById('map-container').appendChild(pin);
        }

        function handlePinClick(isTarget, pinElement) {
            attempts++;
            const feedback = document.getElementById('map-feedback');
            
            if(isTarget) {
                hits++;
                pinElement.style.backgroundColor = 'var(--success)';
                feedback.innerText = "Alvo Confirmado! Baixando Dossiê...";
                feedback.style.color = 'var(--success)';
                updateHUD();
                
                // Desabilita cliques
                document.querySelectorAll('.radar-pin').forEach(p => p.style.pointerEvents = 'none');
                
                setTimeout(() => loadDossierPhase(), 1200);
            } else {
                pinElement.style.backgroundColor = 'var(--danger)';
                pinElement.style.boxShadow = 'none';
                feedback.innerText = "Coordenada Errada. Tente outro sinal de radar.";
                feedback.style.color = 'var(--danger)';
                updateHUD();
            }
        }

        // --- FASE 2: DOSSIÊ E QUIZ ---
        function loadDossierPhase() {
            // Preenche textos
            document.getElementById('dossier-title').innerText = `Dossiê: ${activeRegion.region}`;
            document.getElementById('dossier-country').innerText = activeRegion.country;
            document.getElementById('dossier-culture').innerText = activeRegion.culture;
            document.getElementById('dossier-history').innerText = activeRegion.history;
            document.getElementById('dossier-task').innerText = activeRegion.task;
            
            // Renderiza Quiz
            document.getElementById('quiz-question').innerText = activeRegion.quiz.q;
            const optionsContainer = document.getElementById('quiz-options');
            optionsContainer.innerHTML = '';
            
            // Embaralha opções
            let options = [...activeRegion.quiz.options].sort(() => Math.random() - 0.5);
            
            const btnNext = document.getElementById('btn-next-mission');
            btnNext.disabled = true;

            options.forEach(opt => {
                const btn = document.createElement('div');
                btn.className = 'quiz-option';
                btn.innerText = opt.text;
                btn.onclick = () => handleQuizAnswer(btn, opt.isCorrect, optionsContainer, btnNext);
                optionsContainer.appendChild(btn);
            });

            switchScreen('dossier');
        }

        function handleQuizAnswer(btnElement, isCorrect, container, nextBtn) {
            // Remove classes antigas
            Array.from(container.children).forEach(child => {
                child.classList.remove('correct', 'wrong');
                child.style.pointerEvents = 'none'; // Trava após responder
            });

            if(isCorrect) {
                btnElement.classList.add('correct');
                nextBtn.disabled = false; // Libera progresso
            } else {
                btnElement.classList.add('wrong');
                // Revela a correta
                Array.from(container.children).forEach(child => {
                    // Busca qual era a correta no array de dados
                    let correctText = activeRegion.quiz.options.find(o => o.isCorrect).text;
                    if(child.innerText === correctText) child.classList.add('correct');
                });
                nextBtn.disabled = false;
            }
        }

        function nextPhase() {
            currentPhase++;
            if (currentPhase < gameData.length) {
                updateHUD();
                loadMapPhase();
            } else {
                loadBossPhase();
            }
        }

        // --- FASE 3: BOSS (MATCHING GAME) ---
        let selectedRegion = null;
        let selectedCountry = null;
        let matchPairsCompleted = 0;

        function loadBossPhase() {
            const grid = document.getElementById('matching-grid');
            grid.innerHTML = '';

            const colRegions = document.createElement('div'); colRegions.className = 'match-col';
            colRegions.innerHTML = '<h4>Movimento/Região</h4>';
            
            const colCountries = document.createElement('div'); colCountries.className = 'match-col';
            colCountries.innerHTML = '<h4>País Soberano</h4>';

            // Embaralha para o grid
            let regionsData = [...gameData].sort(() => Math.random() - 0.5);
            let countriesData = [...gameData].sort(() => Math.random() - 0.5);

            regionsData.forEach(item => {
                let div = document.createElement('div');
                div.className = 'match-item region-item';
                div.innerText = item.region;
                div.dataset.id = item.id;
                div.onclick = () => selectMatchItem('region', div);
                colRegions.appendChild(div);
            });

            countriesData.forEach(item => {
                let div = document.createElement('div');
                div.className = 'match-item country-item';
                div.innerText = item.country;
                div.dataset.id = item.id;
                div.onclick = () => selectMatchItem('country', div);
                colCountries.appendChild(div);
            });

            grid.appendChild(colRegions);
            grid.appendChild(colCountries);
            
            matchPairsCompleted = 0;
            switchScreen('boss');
        }

        function selectMatchItem(type, element) {
            if(element.classList.contains('matched')) return;

            // Remove seleção anterior da mesma coluna
            document.querySelectorAll(`.${type}-item`).forEach(el => el.classList.remove('selected'));
            element.classList.add('selected');

            if(type === 'region') selectedRegion = element;
            if(type === 'country') selectedCountry = element;

            checkMatch();
        }

        function checkMatch() {
            if(selectedRegion && selectedCountry) {
                if(selectedRegion.dataset.id === selectedCountry.dataset.id) {
                    // Acerto
                    selectedRegion.classList.remove('selected');
                    selectedCountry.classList.remove('selected');
                    selectedRegion.classList.add('matched');
                    selectedCountry.classList.add('matched');
                    
                    selectedRegion = null;
                    selectedCountry = null;
                    matchPairsCompleted++;

                    if(matchPairsCompleted === gameData.length) {
                        setTimeout(() => switchScreen('victory'), 1000);
                    }
                } else {
                    // Erro
                    selectedRegion.classList.add('error');
                    selectedCountry.classList.add('error');
                    
                    setTimeout(() => {
                        selectedRegion.classList.remove('error', 'selected');
                        selectedCountry.classList.remove('error', 'selected');
                        selectedRegion = null;
                        selectedCountry = null;
                    }, 500);
                }
            }
        }
    </script>
</body>
</html>
